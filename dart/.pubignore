# pub uses THIS file (not .gitignore) when publishing, so the prebuilt native
# libraries (gitignored, fetched via tool/fetch_native.dart) ARE included.
# Exclude only build artifacts and caches.
.dart_tool/
build/
pubspec.lock
*.iml
.flutter-plugins
.flutter-plugins-dependencies

example/build/
example/.dart_tool/
example/pubspec.lock
example/.gradle/
example/android/.gradle/
example/ios/Pods/
example/ios/.symlinks/
example/**/ephemeral/
example/**/*.iml

# wasm bundle: keep only the JS glue + the .wasm; drop the extras
assets/wasm/*.d.ts
assets/wasm/package.json
assets/wasm/README.md
assets/wasm/LICENSE-APACHE
assets/wasm/LICENSE-MIT
